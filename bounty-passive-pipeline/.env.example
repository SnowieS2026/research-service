# Bounty Passive Pipeline
Environment variables example

# Logging
LOG_LEVEL=info

# Dry run (default true – no live network calls)
DRY_RUN=true

# ── OSINT ────────────────────────────────────────────────────────────────────
# Local SearxNG instance for OSINT searches (recommended for reliability)
# Start with: docker run -d --name searxng -p 8080:8080 -v searxng:/etc/searxng --restart unless-stopped searxng/searxng:latest
SEARXNG_URL=http://localhost:8080
