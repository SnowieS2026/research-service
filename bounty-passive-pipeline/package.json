{
  "name": "bounty-passive-pipeline",
  "version": "0.1.0",
  "description": "Read-only browser-only bug bounty metadata collector",
  "main": "dist/src/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/src/index.js",
    "test": "npm run build && playwright test",
    "pipeline": "npm run build && node dist/src/index.js",
    "discover": "npm run build && node dist/src/index.js --discover-only",
    "osint": "npm run build && cross-env SEARXNG_URL=http://localhost:8080 node dist/src/osint/index.js",
    "agents": "npm run build && node dist/src/agents/run.js",
    "agent": "npm run build && node dist/src/index.js --agent"
  },
  "author": "",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "chromadb": "^3.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.2",
    "@types/better-sqlite3": "^7.6.11",
    "cross-env": "^10.1.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  }
}
